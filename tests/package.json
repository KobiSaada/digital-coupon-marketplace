{
  "name": "coupon-marketplace-tests",
  "version": "1.0.0",
  "description": "API Tests for Digital Coupon Marketplace",
  "scripts": {
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:reseller": "jest reseller.test.js --verbose",
    "test:admin": "jest admin.test.js --verbose",
    "test:customer": "jest customer.test.js --verbose",
    "test:all": "jest --runInBand --verbose"
  },
  "keywords": ["testing", "jest", "api", "reseller"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "axios": "^1.6.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 10000,
    "verbose": true,
    "collectCoverageFrom": [
      "**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov", "html"]
  }
}
